{
  "name": "vite-react-app",
  "version": "1.0.0",
  "homepage": "https://github.com/lpke/vite-react-app",
  "author": "luke@lpdev.io",
  "description": "React/Vite frontend boilerplate",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:nohost": "vite",
    "preview": "vite preview --host 0.0.0.0",
    "preview:nohost": "vite preview",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write",
    "format:all": "prettier --write ."
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "license": "AGPL-3.0-only"
}
